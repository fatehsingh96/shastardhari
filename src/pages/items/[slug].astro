---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('items');
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const backLink = item.data.status === 'sold' ? '/sold' : '/';
const backLabel = item.data.status === 'sold' ? 'Back to Sold' : 'Back to Inventory';
---

<Base title={item.data.title} description={`${item.data.title} — ${item.data.origin}, ${item.data.period}`}>
  <div class="container">
    <a href={backLink} class="back-link">← {backLabel}</a>

    <div class="detail-grid" style="margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 48px;">
      <div class="detail-images">
        <div class="detail-cover">
          <img src={item.data.coverImage} alt={item.data.title} />
        </div>
        {item.data.images && item.data.images.length > 0 && (
          <div class="detail-thumbs">
            {item.data.images.map((img: string) => (
              <div class="detail-thumb">
                <img src={img} alt={item.data.title} loading="lazy" />
              </div>
            ))}
          </div>
        )}
      </div>

      <div class="detail-info">
        <p class="label-sm">{item.data.origin} · {item.data.period}</p>
        <h2 class="heading-lg" style="margin-top: 16px;">{item.data.title}</h2>
        <div class="line-reveal" style="margin: 28px 0;"></div>
        <div class="body-text item-description">
          <Content />
        </div>
        {item.data.status === 'available' && (
          <a href="/enquire" class="btn" style="margin-top: 36px;">Enquire</a>
        )}
        {item.data.status === 'sold' && (
          <p class="label" style="margin-top: 36px; color: var(--color-subtle);">Sold</p>
        )}
      </div>
    </div>
  </div>
</Base>

<style>
  .back-link {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .detail-cover {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #111;
  }

  .detail-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .detail-thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 8px;
  }

  .detail-thumb {
    aspect-ratio: 1;
    overflow: hidden;
    background: #111;
  }

  .detail-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .detail-thumb img:hover {
    opacity: 1;
  }

  .detail-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .item-description :global(p) {
    margin-bottom: 1em;
  }

  .item-description :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
