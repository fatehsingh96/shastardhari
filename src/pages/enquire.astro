---
import Base from '../layouts/Base.astro';
---

<Base title="Enquire">
  <div class="container-narrow">
    <h2 class="heading-lg fade-up">Enquire</h2>
    <p class="body-text fade-up stagger-1" style="margin-top: 12px; margin-bottom: 48px;">
      For enquiries regarding any piece in the collection,
      or to discuss commissions and acquisitions, please use the form below.
    </p>

    <!--
      Replace YOUR_FORM_ID below with your Formspree form ID.
      Sign up free at https://formspree.io — you'll get a URL like:
      https://formspree.io/f/xabcdefg
    -->
    <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="enquiry-form fade-up stagger-2">
      <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <input type="text" name="name" class="form-input" placeholder="Name" required />
        <input type="email" name="email" class="form-input" placeholder="Email" required />
      </div>
      <input type="text" name="subject" class="form-input" placeholder="Subject" />
      <textarea name="message" class="form-input" placeholder="Message" rows="6" required style="resize: vertical;"></textarea>
      <button type="submit" class="btn">Send Enquiry</button>
    </form>
  </div>
</Base>

<style>
  .enquiry-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .enquiry-form .btn {
    align-self: flex-start;
    margin-top: 8px;
  }
</style>
